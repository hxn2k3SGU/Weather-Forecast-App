<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".WeatherMapActivity">

    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/mapOverlayContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/map_action_button_bg"
            android:backgroundTint="#D2343C22"
            android:minWidth="0dp"
            android:paddingStart="20dp"
            android:paddingTop="12dp"
            android:paddingEnd="20dp"
            android:paddingBottom="12dp"
            android:text="Xong"
            android:textAllCaps="false"
            android:textColor="#FFF8EE"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/modeContainer"
            android:layout_width="168dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/map_overlay_panel"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lop phu"
                android:textColor="#FFF4DA"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnModeTemperature"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/map_mode_button_bg"
                android:minHeight="0dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="Nhiet do"
                android:textAllCaps="false"
                android:textColor="#FFF8EE" />

            <Button
                android:id="@+id/btnModeCloudCover"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/map_mode_button_bg"
                android:minHeight="0dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="May"
                android:textAllCaps="false"
                android:textColor="#FFF8EE" />

            <Button
                android:id="@+id/btnModePrecipitation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/map_mode_button_bg"
                android:minHeight="0dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="Mua"
                android:textAllCaps="false"
                android:textColor="#FFF8EE" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/legendCard"
            android:layout_width="168dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/map_overlay_panel"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/legendTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhiet do (C)"
                android:textColor="#FFF4DA"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/legendText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="2dp"
                android:text="Dang tai lop phu..."
                android:textColor="#D7E8D2"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="176dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <View
                    android:id="@+id/legendGradientBar"
                    android:layout_width="14dp"
                    android:layout_height="match_parent"
                    android:background="#AAFFFFFF" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/legendValue1"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="top"
                        android:text="50"
                        android:textColor="#FFF7E7"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/legendValue2"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="top"
                        android:text="40"
                        android:textColor="#FFF7E7"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/legendValue3"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="top"
                        android:text="30"
                        android:textColor="#FFF7E7"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/legendValue4"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="top"
                        android:text="20"
                        android:textColor="#FFF7E7"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/legendValue5"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="top"
                        android:text="10"
                        android:textColor="#FFF7E7"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/legendValue6"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="bottom"
                        android:text="-10"
                        android:textColor="#FFF7E7"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
